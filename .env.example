# ============================================================
# Enterprise AI Agent Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL
POSTGRES_DB=agentplatform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-postgres

# Shared service connection strings (used by all backend services)
DATABASE_URL=postgresql+asyncpg://postgres:changeme-postgres@postgres:5432/agentplatform

# Redis
REDIS_URL=redis://redis:6379

# Qdrant
QDRANT_URL=http://qdrant:6333

# Ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.2

# Gateway
ADMIN_SECRET=changeme-admin-secret

# Internal service auth (shared secret between services)
INTERNAL_SECRET=changeme-internal-secret

# Service URLs (internal Docker network)
AGENT_CONFIG_SERVICE_URL=http://agent-config-service:8001
SESSION_SERVICE_URL=http://session-service:8002
MEMORY_SERVICE_URL=http://memory-service:8003
AUDIT_SERVICE_URL=http://audit-service:8004

# Memory settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
SHORT_TERM_TTL_HOURS=24
SHORT_TERM_MAX_MESSAGES=50

# Cost metering
TOKEN_COST_PER_UNIT=0.00001

# Kafka (internal — usually no need to change)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# MinIO (S3-compatible blob store for audit log archival)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_AUDIT_BUCKET=audit-logs

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme-grafana
